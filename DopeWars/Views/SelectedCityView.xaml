<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    Title="{Binding Title}"
    x:Class="DopeWars.Views.SelectedCityView"
    x:DataType="vm:SelectedCityViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:components="clr-namespace:DopeWars.Components"
    xmlns:models="clr-namespace:DopeWars.Models"
    xmlns:vm="clr-namespace:DopeWars.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Grid RowDefinitions="30,*">
        <Label Grid.Row="0" Text="{Binding Title, StringFormat='you are in {0}'}" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding ListOfDrugs}">
            <CollectionView.Header>
                <Label
                    FontSize="20"
                    HorizontalOptions="Center"
                    Text="Select A drug" />
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CityDrug">
                    <Grid
                        Padding="10"
                        RowDefinitions="50"
                        RowSpacing="10">
                        <Border>
                            <components:CustomButton
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SelectedCityViewModel}}, Path=SelectionCommand}"
                                CommandParameter="{Binding .}"
                                Grid.Row="0">
                                <components:CustomButton.Text>
                                    <MultiBinding StringFormat="{}{0} sells here for ${1}">
                                        <Binding Path="Name" />
                                        <Binding Path="Price" />
                                    </MultiBinding>
                                </components:CustomButton.Text>
                            </components:CustomButton>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
